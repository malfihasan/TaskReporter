# Frontend Environment Variables
# Copy this to .env.local and update values

# API URL - Update this to your PythonAnywhere backend URL
# Replace YOUR_USERNAME with your actual PythonAnywhere username
NEXT_PUBLIC_API_URL=https://YOUR_USERNAME.pythonanywhere.com/api

# Alternative: Render.com (has sleep issues on free tier)
# NEXT_PUBLIC_API_URL=https://taskreporter-api.onrender.com/api
